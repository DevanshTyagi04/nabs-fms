{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@packages/design-tokens": [
        "../packages/design-tokens/src/index.ts"
      ],
      "@packages/shared-types": [
        "../packages/shared-types/src/index.ts"
      ],
      "@packages/constants": [
        "../packages/constants/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
