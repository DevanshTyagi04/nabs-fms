# ==========================================
# Universal .gitignore for NABS Workspace
# ==========================================

# Dependencies
node_modules
**/node_modules
**/node_modules/**
**/.package-lock.json
jspm_packages/
web_modules/
.pnpm-store/

# Environment variables & secrets
.env
.env.*
!.env.example
!.env.template
*.env
*.pem
*.key
*.cert

# Build outputs & caches
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/
**/coverage/
.output/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.tsbuildinfo

# Logs & Debugging
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Database & SQLite files
*.db
*.sqlite
*.sqlite3
*.sqlite-journal

# IDE & Editor configurations
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# OS / System generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary & Uploads
tmp/
temp/
**/uploads/
