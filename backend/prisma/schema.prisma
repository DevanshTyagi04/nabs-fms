// ==============================================================================
// NABS Field Service Management (FSM) Platform - Production Hardened Prisma Schema
// Database: Neon PostgreSQL
// ORM: Prisma
// Primary Keys: UUID v4 for all entities
// Strict Referential Integrity & Optimistic Concurrency Control
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================================================
// ENUMS
// ==============================================================================

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum VendorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VendorAvailabilityStatus {
  AVAILABLE
  BUSY
  ON_LEAVE
  OFFLINE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum RequestSource {
  AMC
  ONE_TIME
  WARRANTY
}

enum AMCStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RequestStatus {
  CREATED
  ASSIGNED
  SURVEY_PENDING
  SURVEY_SUBMITTED
  SURVEY_APPROVED
  ESTIMATE_CREATED
  AWAITING_APPROVAL
  ADVANCE_PENDING
  ADVANCE_RECEIVED
  SCHEDULED
  IN_PROGRESS
  WORK_COMPLETED
  QUALITY_CHECK
  FINAL_PAYMENT_PENDING
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum SurveyStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SUPERSEDED
}

enum SurveySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EstimateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REVISED
  SUPERSEDED
}

enum WorkOrderStatus {
  ASSIGNED
  SCHEDULED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentType {
  ADVANCE
  PARTIAL
  MILESTONE
  FINAL
  REFUND
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
  CASH
  BANK_TRANSFER
  MANUAL
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  BANK_TRANSFER
  CASH
  WALLET
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum StorageProvider {
  S3
  GCS
  AZURE_BLOB
  LOCAL
}

enum NotificationType {
  SYSTEM
  REQUEST_STATUS
  SURVEY_UPDATE
  ESTIMATE_UPDATE
  WORK_ORDER_UPDATE
  PAYMENT_CONFIRMATION
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  APPROVAL
}

// ==============================================================================
// 1. AUTHENTICATION & IDENTITY DOMAIN
// ==============================================================================

model User {
  id              String      @id @default(uuid()) @db.Uuid
  email           String      @unique
  phone           String      @unique
  passwordHash    String
  role            UserRole
  status          UserStatus  @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLogin       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Profiles (1:1)
  customerProfile CustomerProfile?
  vendorProfile   VendorProfile?
  adminProfile    AdminProfile?

  // Infrastructure & Log Relations
  refreshTokens          RefreshToken[]
  comments               Comment[]               @relation("UserComments")
  notifications          Notification[]          @relation("RecipientNotifications")
  performedAuditLogs     AuditLog[]              @relation("PerformedByAuditLogs")
  statusChanges          ServiceRequestHistory[] @relation("ChangedByStatusHistory")
  workStatusChanges      WorkStatusHistory[]     @relation("WorkStatusChangedBy")
  workTimelineEvents     WorkTimeline[]          @relation("WorkTimelineActor")
  uploadedAttachments    Attachment[]            @relation("UploadedByAttachments")
  avatarAttachments      Attachment[]            @relation("UserAvatarAttachments")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  tokenHash         String    @unique
  deviceName        String?
  ipAddress         String?
  userAgent         String?
  platform          String?
  browser           String?
  expiresAt         DateTime
  revokedAt         DateTime?
  revokedReason     String?
  replacedByTokenId String?   @db.Uuid
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model CustomerProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @db.Uuid
  firstName   String
  lastName    String
  companyName String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses       Address[]
  amcSubscriptions AMCSubscription[]
  serviceRequests ServiceRequest[]
  comments        Comment[]
  attachments     Attachment[]

  @@index([userId])
  @@map("customer_profiles")
}

model VendorProfile {
  id                 String                   @id @default(uuid()) @db.Uuid
  userId             String                   @unique @db.Uuid
  businessName       String
  companyName        String?
  gstNumber          String?
  panNumber          String?
  secondaryPhone     String?
  yearsExperience    Int                      @default(0)
  bio                String?
  profileImage       String?
  availabilityStatus VendorAvailabilityStatus @default(AVAILABLE)
  averageRating      Decimal                  @default(0.00) @db.Decimal(3, 2)
  totalCompletedJobs Int                      @default(0)
  verificationStatus VendorVerificationStatus @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          VendorSkill[]
  serviceRequests ServiceRequest[] @relation("AssignedVendorRequests")
  surveys         Survey[]
  workOrders      WorkOrder[]
  comments        Comment[]
  attachments     Attachment[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([availabilityStatus])
  @@index([averageRating])
  @@map("vendor_profiles")
}

model AdminProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @db.Uuid
  department  String?
  permissions String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_profiles")
}

// ==============================================================================
// 2. LOCATION & SUBSCRIPTION DOMAIN
// ==============================================================================

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  customerId   String      @db.Uuid
  label        String
  addressType  AddressType @default(HOME)
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  state        String
  country      String
  postalCode   String
  latitude     Decimal?    @db.Decimal(10, 8)
  longitude    Decimal?    @db.Decimal(11, 8)
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  customer        CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceRequests ServiceRequest[]

  @@index([customerId])
  @@index([city])
  @@index([postalCode])
  @@index([addressType])
  @@map("addresses")
}

model AMCSubscription {
  id             String    @id @default(uuid()) @db.Uuid
  customerId     String    @db.Uuid
  planName       String
  startDate      DateTime
  endDate        DateTime
  status         AMCStatus @default(ACTIVE)
  visitsIncluded Int
  visitsUsed     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer        CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  serviceRequests ServiceRequest[]

  @@index([customerId])
  @@index([status])
  @@map("amc_subscriptions")
}

// ==============================================================================
// 3. MASTER CATALOG DOMAIN
// ==============================================================================

model ServiceCategory {
  id                String    @id @default(uuid()) @db.Uuid
  name              String    @unique
  description       String?
  icon              String?
  iconUrl           String?
  color             String?
  displayOrder      Int       @default(0)
  estimatedDuration Int?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  vendorSkills    VendorSkill[]
  serviceRequests ServiceRequest[]

  @@index([name])
  @@index([isActive])
  @@index([displayOrder])
  @@map("service_categories")
}

model VendorSkill {
  id                String     @id @default(uuid()) @db.Uuid
  vendorId          String     @db.Uuid
  categoryId        String     @db.Uuid
  yearsOfExperience Int        @default(0)
  skillLevel        SkillLevel @default(INTERMEDIATE)
  isPrimary         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  vendor   VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([vendorId, categoryId])
  @@index([vendorId])
  @@index([categoryId])
  @@index([skillLevel])
  @@map("vendor_skills")
}

// ==============================================================================
// 4. CORE WORKFLOW DOMAIN
// ==============================================================================

model ServiceRequest {
  id                String        @id @default(uuid()) @db.Uuid
  ticketNumber      String        @unique
  source            RequestSource @default(ONE_TIME)
  customerId        String        @db.Uuid
  addressId         String        @db.Uuid
  serviceCategoryId String        @db.Uuid
  amcSubscriptionId String?       @db.Uuid
  assignedVendorId  String?       @db.Uuid
  title             String
  description       String
  priority          Priority      @default(MEDIUM)
  status            RequestStatus @default(CREATED)
  preferredDate     DateTime?
  version           Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer        CustomerProfile        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  address         Address                @relation(fields: [addressId], references: [id], onDelete: Restrict)
  serviceCategory ServiceCategory        @relation(fields: [serviceCategoryId], references: [id], onDelete: Restrict)
  amcSubscription AMCSubscription?       @relation(fields: [amcSubscriptionId], references: [id], onDelete: SetNull)
  assignedVendor  VendorProfile?         @relation("AssignedVendorRequests", fields: [assignedVendorId], references: [id], onDelete: SetNull)

  statusHistory   ServiceRequestHistory[]
  surveys         Survey[]
  estimates       Estimate[]
  workOrders      WorkOrder[]
  payments        Payment[]
  comments        Comment[]
  attachments     Attachment[]

  @@index([ticketNumber])
  @@index([customerId])
  @@index([assignedVendorId])
  @@index([serviceCategoryId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("service_requests")
}

model ServiceRequestHistory {
  id               String         @id @default(uuid()) @db.Uuid
  serviceRequestId String         @db.Uuid
  fromStatus       RequestStatus?
  toStatus         RequestStatus
  changedById      String         @db.Uuid
  remarks          String?
  createdAt        DateTime       @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  changedBy      User           @relation("ChangedByStatusHistory", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([serviceRequestId])
  @@index([toStatus])
  @@index([createdAt])
  @@map("service_request_history")
}

model Survey {
  id               String       @id @default(uuid()) @db.Uuid
  serviceRequestId String       @db.Uuid
  vendorId         String       @db.Uuid
  version          Int          @default(1)
  status           SurveyStatus @default(DRAFT)
  notes            String?
  startedAt        DateTime?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Restrict)
  vendor         VendorProfile  @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items          SurveyItem[]
  estimates      Estimate[]
  comments       Comment[]
  attachments    Attachment[]

  @@index([serviceRequestId])
  @@index([vendorId])
  @@index([status])
  @@map("surveys")
}

model SurveyItem {
  id             String         @id @default(uuid()) @db.Uuid
  surveyId       String         @db.Uuid
  area           String
  element        String
  observation    String
  actionRequired String?
  severity       SurveySeverity @default(MEDIUM)
  sortOrder      Int            @default(1)
  isMandatory    Boolean        @default(false)
  photoRequired  Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  survey      Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  comments    Comment[]
  attachments Attachment[]

  @@index([surveyId])
  @@index([sortOrder])
  @@index([severity])
  @@map("survey_items")
}

model Estimate {
  id                 String         @id @default(uuid()) @db.Uuid
  serviceRequestId   String         @db.Uuid
  surveyId           String?        @db.Uuid
  version            Int            @default(1)
  status             EstimateStatus @default(DRAFT)
  subtotal           Decimal        @db.Decimal(12, 2)
  taxAmount          Decimal        @db.Decimal(12, 2)
  discountAmount     Decimal        @default(0.00) @db.Decimal(12, 2)
  totalAmount        Decimal        @db.Decimal(12, 2)
  termsAndConditions String?
  validUntil         DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Restrict)
  survey         Survey?        @relation(fields: [surveyId], references: [id], onDelete: SetNull)
  items          EstimateItem[]
  workOrders     WorkOrder[]
  comments       Comment[]
  attachments    Attachment[]

  @@index([serviceRequestId])
  @@index([status])
  @@index([validUntil])
  @@map("estimates")
}

model EstimateItem {
  id          String   @id @default(uuid()) @db.Uuid
  estimateId  String   @db.Uuid
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  discount    Decimal  @default(0.00) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
  @@map("estimate_items")
}

// ==============================================================================
// 5. EXECUTION DOMAIN
// ==============================================================================

model WorkOrder {
  id               String          @id @default(uuid()) @db.Uuid
  workOrderNumber  String          @unique
  serviceRequestId String          @db.Uuid
  estimateId       String?         @db.Uuid
  assignedVendorId String          @db.Uuid
  status           WorkOrderStatus @default(ASSIGNED)
  scheduledStart   DateTime
  scheduledEnd     DateTime
  estimatedDuration Int?
  actualStartTime  DateTime?
  actualEndTime    DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  version          Int             @default(1)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  serviceRequest ServiceRequest      @relation(fields: [serviceRequestId], references: [id], onDelete: Restrict)
  estimate       Estimate?           @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  assignedVendor VendorProfile       @relation(fields: [assignedVendorId], references: [id], onDelete: Restrict)
  tasks          WorkTask[]
  timelineEvents WorkTimeline[]
  statusHistory  WorkStatusHistory[]
  comments       Comment[]
  attachments    Attachment[]

  @@index([workOrderNumber])
  @@index([serviceRequestId])
  @@index([assignedVendorId])
  @@index([status])
  @@index([scheduledStart])
  @@map("work_orders")
}

model WorkTask {
  id             String     @id @default(uuid()) @db.Uuid
  workOrderId    String     @db.Uuid
  description    String
  remarks        String?
  sequenceNumber Int        @default(1)
  estimatedHours Decimal?   @db.Decimal(5, 2)
  actualHours    Decimal?   @db.Decimal(5, 2)
  status         TaskStatus @default(PENDING)
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  workOrder   WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  comments    Comment[]
  attachments Attachment[]

  @@index([workOrderId])
  @@index([sequenceNumber])
  @@index([status])
  @@map("work_tasks")
}

model WorkTimeline {
  id               String   @id @default(uuid()) @db.Uuid
  workOrderId      String   @db.Uuid
  eventTitle       String
  eventDescription String?
  actorId          String?  @db.Uuid
  timestamp        DateTime @default(now())
  createdAt        DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  actor     User?     @relation("WorkTimelineActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([timestamp])
  @@map("work_timelines")
}

model WorkStatusHistory {
  id          String           @id @default(uuid()) @db.Uuid
  workOrderId String           @db.Uuid
  fromStatus  WorkOrderStatus?
  toStatus    WorkOrderStatus
  reason      String?
  changedById String           @db.Uuid
  changedAt   DateTime         @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  changedBy User      @relation("WorkStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([workOrderId])
  @@index([changedAt])
  @@map("work_status_history")
}

// ==============================================================================
// 6. FINANCIAL DOMAIN
// ==============================================================================

model Payment {
  id                   String         @id @default(uuid()) @db.Uuid
  paymentNumber        String         @unique
  serviceRequestId     String         @db.Uuid
  amount               Decimal        @db.Decimal(12, 2)
  type                 PaymentType
  status               PaymentStatus  @default(PENDING)
  gateway              PaymentGateway @default(RAZORPAY)
  gatewayTransactionId String?
  gatewayOrderId       String?
  paymentMethod        PaymentMethod?
  paidAt               DateTime?
  version              Int            @default(1)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Restrict)
  invoice        Invoice?
  comments       Comment[]
  attachments    Attachment[]

  @@index([paymentNumber])
  @@index([serviceRequestId])
  @@index([status])
  @@index([type])
  @@index([gateway])
  @@index([gatewayTransactionId])
  @@map("payments")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique
  paymentId     String        @unique @db.Uuid
  status        InvoiceStatus @default(ISSUED)
  totalAmount   Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @db.Decimal(12, 2)
  dueAmount     Decimal       @db.Decimal(12, 2)
  dueDate       DateTime?
  issuedAt      DateTime      @default(now())
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payment     Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  comments    Comment[]
  attachments Attachment[]

  @@index([invoiceNumber])
  @@index([paymentId])
  @@index([status])
  @@map("invoices")
}

// ==============================================================================
// 7. CROSS-CUTTING & INFRASTRUCTURE DOMAIN (EXPLICIT REFERENTIAL INTEGRITY)
// ==============================================================================

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  comment   String
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Explicit Optional Foreign Keys for Full Referential Integrity & Cascade Deletes
  serviceRequestId  String? @db.Uuid
  surveyId          String? @db.Uuid
  surveyItemId      String? @db.Uuid
  estimateId        String? @db.Uuid
  workOrderId       String? @db.Uuid
  workTaskId        String? @db.Uuid
  paymentId         String? @db.Uuid
  invoiceId         String? @db.Uuid
  vendorProfileId   String? @db.Uuid
  customerProfileId String? @db.Uuid

  // Prisma Relations with Cascade Delete Rules
  user            User             @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  serviceRequest  ServiceRequest?  @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  survey          Survey?          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  surveyItem      SurveyItem?      @relation(fields: [surveyItemId], references: [id], onDelete: Cascade)
  estimate        Estimate?        @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder?       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workTask        WorkTask?        @relation(fields: [workTaskId], references: [id], onDelete: Cascade)
  payment         Payment?         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  vendorProfile   VendorProfile?   @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  customerProfile CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serviceRequestId])
  @@index([surveyId])
  @@index([surveyItemId])
  @@index([estimateId])
  @@index([workOrderId])
  @@index([workTaskId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([vendorProfileId])
  @@index([customerProfileId])
  @@index([createdAt])
  @@map("comments")
}

model Attachment {
  id              String          @id @default(uuid()) @db.Uuid
  fileName        String
  url             String
  mimeType        String
  fileSize        Int
  storageProvider StorageProvider @default(S3)
  checksum        String?
  uploadedById    String          @db.Uuid
  uploadedAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Explicit Optional Foreign Keys for Full Referential Integrity & Cascade Deletes
  serviceRequestId  String? @db.Uuid
  surveyId          String? @db.Uuid
  surveyItemId      String? @db.Uuid
  estimateId        String? @db.Uuid
  workOrderId       String? @db.Uuid
  workTaskId        String? @db.Uuid
  paymentId         String? @db.Uuid
  invoiceId         String? @db.Uuid
  userAvatarId      String? @db.Uuid
  vendorProfileId   String? @db.Uuid
  customerProfileId String? @db.Uuid

  // Prisma Relations with Cascade Delete Rules
  uploadedBy      User             @relation("UploadedByAttachments", fields: [uploadedById], references: [id], onDelete: Cascade)
  serviceRequest  ServiceRequest?  @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  survey          Survey?          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  surveyItem      SurveyItem?      @relation(fields: [surveyItemId], references: [id], onDelete: Cascade)
  estimate        Estimate?        @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder?       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workTask        WorkTask?        @relation(fields: [workTaskId], references: [id], onDelete: Cascade)
  payment         Payment?         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userAvatar      User?            @relation("UserAvatarAttachments", fields: [userAvatarId], references: [id], onDelete: Cascade)
  vendorProfile   VendorProfile?   @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  customerProfile CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([uploadedById])
  @@index([serviceRequestId])
  @@index([surveyId])
  @@index([surveyItemId])
  @@index([estimateId])
  @@index([workOrderId])
  @@index([workTaskId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([userAvatarId])
  @@index([vendorProfileId])
  @@index([customerProfileId])
  @@index([checksum])
  @@map("attachments")
}

model Notification {
  id             String                     @id @default(uuid()) @db.Uuid
  recipientId    String                     @db.Uuid
  title          String
  body           String
  type           NotificationType
  deliveryStatus NotificationDeliveryStatus @default(PENDING)
  isRead         Boolean                    @default(false)
  sentAt         DateTime?
  readAt         DateTime?
  createdAt      DateTime                   @default(now())

  recipient User @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([deliveryStatus])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  entityType    String
  entityId      String      @db.Uuid
  action        AuditAction
  oldData       Json?
  newData       Json?
  performedById String?     @db.Uuid
  performedAt   DateTime    @default(now())

  performedBy User? @relation("PerformedByAuditLogs", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([action])
  @@index([performedAt])
  @@map("audit_logs")
}
